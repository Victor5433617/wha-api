          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const chats = body.response || body;",
                  "const arr = Array.isArray(chats) ? chats : [];",
                  "const names = arr.map(c => c && (c.name || c.formattedTitle || (c.contact && (c.contact.name || c.contact.formattedName)) || c.pushname || (c.id && (c.id._serialized || c.id)) || 'unknown'));",
                  "pm.environment.set('lastChatNames', names.join(', '));",
                  "const template = `<div style=\"font-family:Arial,Helvetica,sans-serif;padding:12px;\"><h3>Chat Names ({{names.length}})</h3><ul>{{#each names}}<li>{{this}}</li>{{/each}}</ul></div>`;",
                  "pm.visualizer.set(template, { names: names });"
                ]
              }
            }
          ]
